# Copy to .env.local for local dev, or set these in your host (e.g. Vercel
# Project Settings → Environment Variables).

# Manager console access:
#   • Leave MANAGER_PASSWORD UNSET  → console is OPEN (public demo, no login).
#   • Set MANAGER_PASSWORD          → console is LOCKED behind that password.
# MANAGER_PASSWORD=change-me-to-something-strong

# Show a one-click "Explore the demo dashboard" button on the login screen
# (only relevant when MANAGER_PASSWORD is set). Optional.
# NEXT_PUBLIC_DEMO_MODE=true

# Public base URL of the deployment. Used for SEO metadata, sitemap, robots
# and the widget embed snippet. No trailing slash.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app